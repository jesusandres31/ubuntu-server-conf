# Source directory on the NAS disk.
BACKUP_SOURCE_DIR=/mnt/ssd/smb/sync

# Rclone destination. Configure the `mega` remote with `rclone config`.
BACKUP_REMOTE=mega:sync

# Only upload files that do not already exist remotely.
BACKUP_IGNORE_EXISTING=true

# Daily at 03:00.
BACKUP_TIMER_ONCALENDAR="*-*-* 03:00:00"
