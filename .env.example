# Server
SERVER_HOSTNAME=thinkcenter
SERVER_USER=ltc

# Network: find the interface with `ip link`.
ETH_IFACE=eno1
ETH_ADDRESS=192.168.0.101/24
GATEWAY=192.168.0.1
DNS="1.1.1.1, 8.8.8.8"

# Optional Wi-Fi. Leave empty for an Ethernet-only server.
WIFI_IFACE=
WIFI_ADDRESS=
WIFI_NETWORK=
WIFI_PASSWORD=

# Storage: find the filesystem UUID and type with `lsblk -f`.
DISK_UUID=0C65-A654
MOUNT_POINT=/mnt/ssd
FS_TYPE=exfat
MOUNT_OPTIONS=defaults,nofail,uid=1000,gid=1000,umask=0002
SHARE_DIR=/mnt/ssd/smb

# For an exFAT external disk, use something like:
# FS_TYPE=exfat
# MOUNT_OPTIONS=defaults,nofail,uid=1000,gid=1000,umask=0002