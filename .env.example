# Server
SERVER_HOSTNAME=thinkcenter
SERVER_USER=ltc

# Network: find the interface with `ip link`.
ETH_IFACE=REPLACE_WITH_INTERFACE
ETH_ADDRESS=192.168.0.101/24
GATEWAY=192.168.0.1
DNS="1.1.1.1, 8.8.8.8"

# Optional Wi-Fi. Leave empty for an Ethernet-only server.
WIFI_IFACE=
WIFI_ADDRESS=192.168.0.102/24
WIFI_NETWORK=
WIFI_PASSWORD=

# Storage: find the filesystem UUID and type with `lsblk -f`.
DISK_UUID=REPLACE_WITH_LSBLK_UUID
MOUNT_POINT=/mnt/ssd
FS_TYPE=ext4
MOUNT_OPTIONS=defaults,nofail
SHARE_DIR=/mnt/ssd/smb

# Docker services
TAILSCALE_AUTH_KEY=replace_me
SAMBA_USER=poli
SAMBA_PASSWORD=replace_me
